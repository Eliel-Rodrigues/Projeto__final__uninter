generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  GERENTE
  ATENDENTE
  CLIENTE
}

enum CanalPedido {
  APP
  TOTEM
  BALCAO
  PICKUP
  WEB
}

model Usuario {
  id         Int         @id @default(autoincrement())
  nome       String
  email      String      @unique
  senha      String
  role       Role        @default(CLIENTE)
  pedidos    Pedido[]
  fidelidade Fidelidade?
}

model Unidade {
  id       Int       @id @default(autoincrement())
  nome     String
  endereco String
  bairro   String
  cidade   String
  cep      Int       @unique
  produtos Produto[]
}

model Produto {
  id        Int     @id @default(autoincrement())
  nome      String 
  preco     Float
  estoque   Int
  unidadeId Int
  itens       Item[]
  unidade   Unidade @relation(fields: [unidadeId], references: [id])
}

model Pedido {
  id          Int         @id @default(autoincrement())
  canalPedido CanalPedido
  clienteId   Int
  status      String  @default("PENDENTE")
  valorTotal  Float
  itens       Item[]
  usuario     Usuario     @relation(fields: [clienteId], references: [id])
}

model Item {
  id         Int    @id @default(autoincrement())
  pedidoId   Int
  produtoId  Int
  quantidade Int
  pedido     Pedido @relation(fields: [pedidoId], references: [id])
  produto     Produto @relation(fields: [produtoId], references: [id])
}

model Fidelidade {
  id        Int     @id @default(autoincrement())
  clienteId Int     @unique
  pontos    Int     @default(0)
  usuario   Usuario @relation(fields: [clienteId], references: [id])
}
